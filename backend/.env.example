# ─────────────────────────────────────────────────────────────────────────────
# Mindexa Backend – Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# Windows (PowerShell):  Copy-Item .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
APP_NAME="Mindexa Platform"
APP_VERSION="0.1.0"
DEBUG=true
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=986104b16962f8f3e1b6d4631148c71ffac35cf7e32b70d5504d3ab1ad37a664
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=mindexa
POSTGRES_PASSWORD=@IPcreator22
POSTGRES_DB=mindexa_db

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_DB_CELERY=1

# ── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Password Policy ───────────────────────────────────────────────────────────
PASSWORD_MIN_LENGTH=8
BCRYPT_ROUNDS=12

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_AI=20/minute

# ── File Upload ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=25
ALLOWED_UPLOAD_EXTENSIONS=pdf,docx,pptx,txt,png,jpg,jpeg

# ── AI / OpenAI ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL_CHAT=gpt-4o
OPENAI_MODEL_EMBEDDING=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# ── Email ────────────────────────────────────────────────────────────────────
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@mindexa.ac
MAIL_PORT=587
MAIL_SERVER=smtp.example.com
MAIL_FROM_NAME="Mindexa Platform"
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# ── Celery ───────────────────────────────────────────────────────────────────
# Set true in tests so Celery tasks run synchronously (no worker needed)
CELERY_TASK_ALWAYS_EAGER=false

# ── Sentry (leave blank to disable) ──────────────────────────────────────────
SENTRY_DSN=
