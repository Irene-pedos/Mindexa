# =============================================================================
# Mindexa Platform — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in all required values.
#
#   cp .env.example .env
#
# REQUIRED fields have no default and MUST be set or the app will refuse to start.
# DO NOT commit .env to version control — it is in .gitignore.
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Mindexa Platform"
APP_VERSION="1.0.0"

# development | staging | production
ENVIRONMENT=development

DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ── Secrets (REQUIRED) ────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=986104b16962f8f3e1b6d4631148c71ffac35cf7e32b70d5504d3ab1ad37a664

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Auth ──────────────────────────────────────────────────────────────────────
EMAIL_VERIFICATION_EXPIRE_MINUTES=1440
PASSWORD_RESET_EXPIRE_MINUTES=60
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
REFRESH_TOKEN_COOKIE_NAME=mindexa_refresh
# Set to true in production (requires HTTPS)
ACCESS_TOKEN_COOKIE_SECURE=false

# ── Database (REQUIRED) ───────────────────────────────────────────────────────
# Sync URL — used by Alembic for migrations
DATABASE_URL=postgresql://mindexa_db:Postgre123@localhost:5432/mindexa_db
# Async URL — derived from DATABASE_URL automatically if left blank
# DATABASE_ASYNC_URL=postgresql+asyncpg://mindexa_db:Postgre123@localhost:5432/mindexa_db

DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_PRE_PING=true
# Set to true only for local SQL debugging — never in production
DATABASE_ECHO=false

# Docker-specific (used in docker-compose.yml)
POSTGRES_DB=mindexa_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Postgre123
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20
REDIS_CACHE_DEFAULT_TTL=300
REDIS_USER_PROFILE_TTL=600
REDIS_ASSESSMENT_TTL=120
REDIS_REVOKED_JTI_TTL=604800

REDIS_PORT=6379

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
# Set to true in test environments for synchronous task execution
CELERY_TASK_ALWAYS_EAGER=false

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_REFRESH_PER_MINUTE=20
RATE_LIMIT_DEFAULT_PER_MINUTE=120

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# Set to true in staging/production for JSON structured logs
LOG_JSON=false
LOG_ACCESS=true

# ── Monitoring ────────────────────────────────────────────────────────────────
METRICS_ENABLED=true
# Optional: Sentry DSN for error tracking
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. NO wildcards in production.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true
FRONTEND_URL=http://localhost:3000

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
SMTP_SSL=false
EMAILS_FROM_EMAIL=noreply@mindexa.ac
EMAILS_FROM_NAME="Mindexa Platform"
# Set to false in production to actually send emails
EMAIL_DEV_MODE=true

# ── File Storage ──────────────────────────────────────────────────────────────
# local | s3
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=uploads
MAX_UPLOAD_SIZE_MB=25
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.doc,.docx,.txt,.png,.jpg,.jpeg

# AWS S3 (required only when STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
# For MinIO or other S3-compatible storage:
# AWS_S3_ENDPOINT_URL=http://localhost:9000

# ── AI / LLM ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
AI_MAX_RETRIES=3
AI_TIMEOUT_SECONDS=30

# ── Vector Store ──────────────────────────────────────────────────────────────
# pgvector | qdrant
VECTOR_STORE=pgvector
PGVECTOR_DIMENSION=1536
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Pagination ────────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ── App port (for docker-compose) ─────────────────────────────────────────────
APP_PORT=8000
